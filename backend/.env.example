# Environment Variables Template
# Copy this to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Payments
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SendGrid Email Service
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@Veloura.com
FROM_NAME=Veloura Hotels

# Twilio SMS/WhatsApp
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Cloudbeds PMS Integration
CLOUDBEDS_CLIENT_ID=your_cloudbeds_client_id
CLOUDBEDS_CLIENT_SECRET=your_cloudbeds_client_secret
CLOUDBEDS_PROPERTY_ID=your_property_id
CLOUDBEDS_BASE_URL=https://hotels.cloudbeds.com/api/v1.2

# SiteMinder Channel Manager
SITEMINDER_API_KEY=your_siteminder_api_key
SITEMINDER_BASE_URL=https://connect.siteminder.com/v1
SITEMINDER_WEBHOOK_KEY=your_siteminder_webhook_key

# Cloudbeds Webhook
CLOUDBEDS_WEBHOOK_KEY=your_cloudbeds_webhook_key

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Amadeus Travel API (flights, hotels, destinations)
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_ENVIRONMENT=test

# Foursquare Places API (location data, recommendations)
FOURSQUARE_API_KEY=your_foursquare_api_key
FOURSQUARE_BASE_URL=https://api.foursquare.com/v3

# Makecorps Service (business operations)
MAKECORPS_API_KEY=your_makecorps_api_key
MAKECORPS_API_SECRET=your_makecorps_api_secret
MAKECORPS_BASE_URL=https://api.makecorps.com/v1
MAKECORPS_WEBHOOK_SECRET=your_makecorps_webhook_secret

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# External Services
WEATHER_API_KEY=your_weather_api_key
CURRENCY_API_KEY=your_currency_api_key

# Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Development Only
SKIP_EMAIL_VERIFICATION=false
SKIP_PAYMENT_VERIFICATION=false
